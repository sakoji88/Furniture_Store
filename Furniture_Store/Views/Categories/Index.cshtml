@model IEnumerable<Category>
@{ ViewData["Title"] = "Категории"; }
<h2>Категории</h2>
<a asp-action="Create" class="btn btn-success mb-2">Добавить категорию</a>
<table class="table table-bordered"><thead><tr><th>Название</th><th>Описание</th><th></th></tr></thead><tbody>
@foreach(var item in Model){
<tr><td>@item.Name</td><td>@item.Description</td><td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a> <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a></td></tr>
}
</tbody></table>
