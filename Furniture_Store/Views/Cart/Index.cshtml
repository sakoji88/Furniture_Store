@model CartPageViewModel
@{ ViewData["Title"] = "Корзина"; }

<h2 class="mb-3">Корзина</h2>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">Корзина пока пуста. Добавьте товары из каталога.</div>
    <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Перейти в каталог</a>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            @foreach (var item in Model.Items)
            {
                <div class="cart-item mb-3">
                    <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "https://via.placeholder.com/120x90?text=Furniture" : item.ImageUrl)" alt="@item.ProductName" />
                    <div class="flex-grow-1">
                        <h6 class="mb-1">@item.ProductName</h6>
                        <div class="text-muted">@item.UnitPrice.ToString("N0") ₽ за шт.</div>
                        <div class="mt-2 d-flex gap-2 align-items-center">
                            <form asp-action="Update" method="post" class="d-flex gap-2 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="100" class="form-control form-control-sm" style="width:90px" />
                                <button class="btn btn-sm btn-outline-primary">Обновить</button>
                            </form>
                            <form asp-action="Remove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </div>
                    </div>
                    <strong>@item.LineTotal.ToString("N0") ₽</strong>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card p-3 shadow-sm">
                <h5>Оформление заказа</h5>
                <p class="text-muted mb-2">Сумма: <strong>@Model.Total.ToString("N0") ₽</strong></p>

                <form asp-action="Checkout" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-2"><label asp-for="RecipientName" class="form-label"></label><input asp-for="RecipientName" maxlength="100" class="form-control" /></div>
                    <div class="mb-2"><label asp-for="Phone" class="form-label"></label><input asp-for="Phone" maxlength="20" class="form-control" /></div>
                    <div class="mb-2"><label asp-for="DeliveryAddress" class="form-label"></label><textarea asp-for="DeliveryAddress" maxlength="200" rows="3" class="form-control"></textarea></div>
                    <button class="btn btn-success w-100">Оформить заказ</button>
                </form>
            </div>
        </div>
    </div>
}

<partial name="_ValidationScriptsPartial" />
