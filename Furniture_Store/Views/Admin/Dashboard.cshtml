@{ ViewData["Title"] = "Админ-панель"; }
<h2>Панель администратора</h2>
<div class="row g-3">
    <div class="col-md-3"><div class="card p-3"><h5>Пользователи</h5><p>@ViewBag.UsersCount</p></div></div>
    <div class="col-md-3"><div class="card p-3"><h5>Товары</h5><p>@ViewBag.ProductsCount</p></div></div>
    <div class="col-md-3"><div class="card p-3"><h5>Категории</h5><p>@ViewBag.CategoriesCount</p></div></div>
    <div class="col-md-3"><div class="card p-3"><h5>Заблокированы</h5><p>@ViewBag.BannedUsersCount</p></div></div>
</div>
<div class="mt-3 d-flex gap-2">
    <a asp-action="Users" class="btn btn-primary">Пользователи</a>
    <a asp-action="Tables" class="btn btn-outline-primary">Таблицы</a>
    <a asp-action="Orders" class="btn btn-outline-dark">Заказы</a>
</div>
