@model IReadOnlyList<Furniture_Store.Models.Order>
@using Furniture_Store.Models
@{ ViewData["Title"] = "Заказы"; }

<h2>Управление заказами</h2>
<div class="table-responsive">
<table class="table table-striped align-middle">
    <thead><tr><th>№</th><th>Пользователь</th><th>Дата</th><th>Сумма</th><th>Статус</th><th></th></tr></thead>
    <tbody>
    @foreach (var order in Model)
    {
        <tr>
            <td>@order.Id</td>
            <td>@order.User?.Email</td>
            <td>@order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
            <td>@order.TotalAmount.ToString("N0") ₽</td>
            <td>@order.Status</td>
            <td>
                <form asp-action="UpdateOrderStatus" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@order.Id" />
                    <select name="status" class="form-select form-select-sm">
                        @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                        {
                            <option value="@status" selected="@(status == order.Status ? "selected" : null)">@status</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-primary">Сохранить</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
