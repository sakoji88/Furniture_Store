@model Product
@{ ViewData["Title"] = "Детали товара"; }
<div class="card shadow-sm">
    <div class="card-body">
        <h3>@Model.Name</h3>
        <p><b>Артикул:</b> @Model.Article</p>
        <p><b>Категория:</b> @Model.Category?.Name</p>
        <p><b>Цена:</b> @Model.Price.ToString("N2") ₽</p>
        <p><b>Материал:</b> @Model.Material</p>
        <p><b>Цвет:</b> @Model.Color</p>
        <p><b>Описание:</b> @Model.Description</p>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
</div>
